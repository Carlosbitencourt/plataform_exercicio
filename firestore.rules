rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is admin
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'agenciaconativa@gmail.com' ||
        request.auth.token.email == 'admin@admin.com' ||
        request.auth.token.email == 'carlos.bitencourt@fitreward.com.br'
      );
    }

    // Users collection
    match /users/{userId} {
      allow read: if true;
      // Broadened update permission for authenticated users to avoid ID/UID mismatch failures
      allow update: if isAuthenticated();
      allow create, delete: if isAuthenticated();
    }

    // TimeSlots collection
    match /timeSlots/{slotId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // CheckIns collection
    match /checkIns/{checkInId} {
      allow read: if true;
      allow create, update: if true; 
      allow delete: if isAdmin();
    }

    // Distributions collection
    match /distributions/{distId} {
      allow read, write: if isAdmin();
    }

    // QRCodes collection
    match /qrCodes/{qrId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categories collection
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Withdrawals collection
    match /withdrawals/{withdrawalId} {
      // Allow authenticated users to read and create withdrawals
      // Restricted update/delete to admins
      allow read, create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
  }
}
